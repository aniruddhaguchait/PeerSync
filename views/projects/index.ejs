<% layout('layouts/boilerplate')%>
<div class="row my-4">
    <div class="col-lg-10 offset-lg-1">
        <h1 class="mb-4 text-center">All Projects</h1>
        <p class="lead text-center mb-5">Browse and join exciting student projects or start your own!</p>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <% for (let project of projects) { %>
                <div class="col">
                    <div class="card project-card h-100">
                        <% if (project.images && project.images.length) { %>
                            <img src="<%= project.images[0].url %>" class="card-img-top" alt="<%= project.title %>">
                        <% } else { %>
                            <img src="https://images.unsplash.com/photo-1553877522-43269d4ea984?q=80&w=1470&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" class="card-img-top" alt="Project Placeholder">
                        <% } %>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title"><%= project.title %></h5>
                            <p class="card-text text-muted small"><%= project.description.substring(0, 100) %>...</p>
                            <div class="mb-2">
                                <% project.tags.forEach(tag => { %>
                                    <span class="badge bg-primary me-1"><%= tag %></span>
                                <% }); %>
                            </div>
                            <p class="card-text mt-auto">
                                <small class="text-muted">Owner: <%= project.owner.username %></small>
                            </p>
                            <div class="mt-2">
                                <a href="/projects/<%= project._id %>" class="btn btn-primary btn-sm">View Project</a>
                            </div>
                        </div>
                        <div class="card-footer text-muted">
                            Status: <span class="badge bg-<%= project.status === 'Completed' ? 'success' : (project.status === 'In Progress' ? 'primary' : 'secondary') %>"><%= project.status %></span>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>