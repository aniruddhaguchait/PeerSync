<% layout('layouts/boilerplate')%>
<div class="row my-4">
    <div class="col-lg-8 offset-lg-2">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="text-center mb-4">
                    <% if (user.profileImage && user.profileImage.url) { %>
                        <img src="<%= user.profileImage.url %>" alt="<%= user.username %>'s profile image" class="profile-img-thumbnail img-fluid">
                    <% } else { %>
                        <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" 
                        alt="Default Avatar" 
                        class="profile-img-thumbnail img-fluid">

                    <% } %>
                    <h1 class="card-title mt-3"><%= user.username %></h1>
                    <p class="text-muted"><%= user.email %></p>
                </div>

                <h4 class="mb-3">About Me</h4>
                <ul class="list-group list-group-flush mb-4">
                    <li class="list-group-item">
                        <strong>Skills:</strong>
                        <% if (user.skills && user.skills.length) { %>
                            <% user.skills.forEach(skill => { %>
                                <span class="badge bg-info text-dark me-1"><%= skill %></span>
                            <% }); %>
                        <% } else { %>
                            <em>No skills listed.</em>
                        <% } %>
                    </li>
                    <li class="list-group-item">
                        <strong>Interests:</strong>
                        <% if (user.interests && user.interests.length) { %>
                            <% user.interests.forEach(interest => { %>
                                <span class="badge bg-secondary me-1"><%= interest %></span>
                            <% }); %>
                        <% } else { %>
                            <em>No interests listed.</em>
                        <% } %>
                    </li>
                    <li class="list-group-item">
                        <strong>Domain Tags:</strong>
                        <% if (user.domainTags && user.domainTags.length) { %>
                            <% user.domainTags.forEach(tag => { %>
                                <span class="badge bg-primary me-1"><%= tag %></span>
                            <% }); %>
                        <% } else { %>
                            <em>No domain tags listed.</em>
                        <% } %>
                    </li>
                </ul>

                <% if (currentUser && currentUser._id.equals(user._id)) { %>
                    <div class="d-grid gap-2 mb-4">
                        <a href="/users/<%= user._id %>/edit" class="btn btn-outline-primary"><i class="fas fa-edit me-2"></i>Edit Profile</a>
                    </div>
                <% } %>

                <h4 class="mb-3">My Projects</h4>
                <% if (user.projects && user.projects.length) { %>
                    <div class="list-group">
                        <% user.projects.forEach(project => { %>
                            <a href="/projects/<%= project._id %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <%= project.title %>
                                <span class="badge bg-<%= project.status === 'Completed' ? 'success' : (project.status === 'In Progress' ? 'primary' : 'secondary') %>"><%= project.status %></span>
                            </a>
                        <% }); %>
                    </div>
                <% } else { %>
                    <p class="text-muted">No projects associated with this user yet.</p>
                <% } %>

            </div>
        </div>
    </div>
</div>