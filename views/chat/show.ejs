<% layout('layouts/boilerplate')%>
<div class="row my-4">
    <div class="col-lg-8 offset-lg-2">
        <h1 class="mb-4 text-center">Chat for Project: <%= project.title %></h1>
        <div class="card shadow-sm">
            <div class="card-body d-flex flex-column" style="height: 500px;">
                <!-- <ul id="chatMessages" class="list-group list-group-flush overflow-auto flex-grow-1 mb-3"
                    data-project-id="<%= project._id %>"
                    data-username="<%= currentUser.username %>">
                    <li class="list-group-item text-muted text-center">No messages yet. Say hello!</li>
                </ul> -->

                <ul id="chatMessages" class="list-group list-group-flush overflow-auto flex-grow-1 mb-3"
                    data-project-id="<%= project._id %>"
                    data-username="<%= currentUser.username %>">
                    <% if (messages.length) { %>
                        <% messages.forEach(m => { %>
                            <li class="list-group-item">
                                <strong><%= m.username %>:</strong> <%= m.message %>
                                <small class="text-muted float-end"><%= new Date(m.timestamp).toLocaleTimeString() %></small>
                            </li>
                        <% }) %>
                    <% } else { %>
                        <li class="list-group-item text-muted text-center">No messages yet. Say hello!</li>
                    <% } %>
                </ul>


                <form id="chatForm" class="input-group">
                    <input type="text" id="chatInput" class="form-control" placeholder="Type your message..." aria-label="Chat message" required>
                    <button class="btn btn-primary" type="submit">Send</button>
                </form>
            </div>
        </div>
        <div class="mt-3 text-center">
            <a href="/projects/<%= project._id %>" class="btn btn-secondary">Back to Project</a>
        </div>
    </div>
</div>