<!-- <nav id="mainNavbar" class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top py-3"> -->
<nav id="mainNavbar" class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top py-3 shadow-sm">

  <div class="container-fluid px-3">

    <!-- Brand -->
    <a class="navbar-brand fw-semibold fs-4" href="/">
        <i class="fa-solid fa-circle-nodes text-info">
        </i><span class="peer-text">Peer</span>Sync
    </a>



    <!-- Toggler button for mobile -->
    <button
      class="navbar-toggler border-0"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNavDropdown"
      aria-controls="navbarNavDropdown"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Navbar links -->
    <div class="collapse navbar-collapse" id="navbarNavDropdown">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="/projects">Projects</a></li>
        <li class="nav-item"><a class="nav-link" href="/projects/new">New Project</a></li>
        <li class="nav-item"><a class="nav-link" href="/users/find-collaborators">Collaborators</a></li>
        <li class="nav-item"><a class="nav-link" href="/projects/analytics/dashboard">Analytics</a></li>
      </ul>

      <!-- Right side (Login / Register / Profile) -->
      <ul class="navbar-nav ms-auto">
        <% if (!currentUser) { %>
          <li class="nav-item">
            <a class="nav-link" href="/users/login">Login</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/users/register">Register</a>
          </li>
        <% } else { %>
          <!-- Dropdown for logged-in user -->
          <li class="nav-item dropdown">
            <a
              class="nav-link dropdown-toggle d-flex align-items-center"
              href="#"
              id="userDropdown"
              role="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
            >
              <% if (currentUser.profileImage && currentUser.profileImage.url) { %>
                <img
                  src="<%= currentUser.profileImage.url %>"
                  alt="Profile"
                  class="profile-small-img me-1"
                />
              <% } %>
              <%= currentUser.username %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
              <li><a class="dropdown-item" href="/users/<%= currentUser._id %>">My Profile</a></li>
              <li><a class="dropdown-item" href="/projects/my-projects">My Projects</a></li>
              <li><hr class="dropdown-divider" /></li>
              <li><a class="dropdown-item text-danger" href="/users/logout">Logout</a></li>
            </ul>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
